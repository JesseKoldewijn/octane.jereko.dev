{
	"name": "octane.jereko.dev",
	"version": "0.0.1",
	"private": true,
	"description": "Jereko personal website — Octane SSR",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"postinstall": "node scripts/patch-packages.mjs && node scripts/generate-tailwind-sources.mjs",
		"predev": "node scripts/generate-tailwind-sources.mjs && node scripts/fetch-external-images.mjs",
		"build": "node scripts/patch-packages.mjs && node scripts/generate-tailwind-sources.mjs && node scripts/fetch-external-images.mjs && node scripts/generate-sitemap.mjs && vite build && node scripts/inject-ssr-stylesheet.mjs",
		"preview": "octane-preview",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint src scripts tests vite.config.ts octane.config.ts vitest.config.ts env.d.ts",
		"lint:fix": "oxlint src scripts tests vite.config.ts octane.config.ts vitest.config.ts env.d.ts --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"knip": "knip",
		"check": "bun run format:check && bun run lint && bun run typecheck && bun run build && bun run test:all && bun run knip",
		"test": "vitest run --project unit --project integration --project component",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:component": "vitest run --project component",
		"test:e2e": "vitest run --project e2e",
		"test:all": "bun run test && bun run test:e2e",
		"test:watch": "vitest",
		"fetch-external-images": "node scripts/fetch-external-images.mjs",
		"generate-sitemap": "node scripts/generate-sitemap.mjs"
	},
	"dependencies": {
		"@octanejs/adapter-vercel": "^0.0.1",
		"@octanejs/motion": "^0.1.2",
		"@octanejs/radix": "^0.1.2",
		"@octanejs/tanstack-router": "^0.1.2",
		"@octanejs/vite-plugin": "^0.1.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"devalue": "^5.8.1",
		"motion": "^12.42.2",
		"octane": "^0.1.3",
		"platformicons": "^9.5.0",
		"tailwind-merge": "^3.6.0",
		"workbox-window": "^7.4.1"
	},
	"devDependencies": {
		"@octanejs/testing-library": "^0.1.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"happy-dom": "^20.10.6",
		"knip": "^6.26.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"tailwindcss": "^4.3.2",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.3.14"
}
