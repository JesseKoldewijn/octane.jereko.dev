{
	"name": "octane.jereko.dev",
	"version": "0.0.1",
	"private": true,
	"description": "Jereko personal website — Octane SSG",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"postinstall": "bun scripts/fetch-external-images.ts",
		"predev": "bun scripts/fetch-external-images.ts",
		"build": "bun scripts/fetch-external-images.ts && bun scripts/generate-sitemap.ts && vite build && bun scripts/prerender-static.ts && bun scripts/adapt-vercel.ts",
		"preview": "bun scripts/static-server.ts",
		"typecheck": "tsc --noEmit && bun scripts/typecheck-tsrx.ts",
		"typecheck:tsrx": "bun scripts/typecheck-tsrx.ts",
		"lint": "oxlint src tests scripts vite vite.config.ts octane.config.ts vitest.config.ts knip.ts env.d.ts octane-jsx.d.ts",
		"lint:fix": "oxlint src tests scripts vite vite.config.ts octane.config.ts vitest.config.ts knip.ts env.d.ts octane-jsx.d.ts --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"knip": "knip",
		"check": "bun run format:check && bun run lint && bun run typecheck && bun run build && bun run test:all && bun run knip",
		"test": "vitest run --project unit --project integration --project component",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:component": "vitest run --project component",
		"test:e2e": "vitest run --project e2e",
		"test:perf": "vitest run --project e2e tests/e2e/performance.e2e.test.ts",
		"lint:chunks": "bun -e \"import { assertHealthyClientChunkGraph } from './scripts/lib/chunk-graph.ts'; assertHealthyClientChunkGraph();\"",
		"ci:act": "act push -j quality -P ubuntu-latest=catthehacker/ubuntu:act-latest --container-architecture linux/amd64 --env ACT=true",
		"test:all": "bun run test && bun run test:e2e",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@octanejs/base-ui": "^0.1.3",
		"@octanejs/motion": "0.1.3",
		"@octanejs/tanstack-router": "0.1.3",
		"@octanejs/vite-plugin": "0.1.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"devalue": "^5.8.1",
		"motion": "^12.42.2",
		"octane": "0.1.4",
		"platformicons": "^9.5.0",
		"tailwind-merge": "^3.6.0",
		"workbox-window": "^7.4.1"
	},
	"devDependencies": {
		"@octanejs/testing-library": "0.1.1",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"chrome-launcher": "^1.2.1",
		"happy-dom": "^20.10.6",
		"knip": "^6.26.0",
		"lighthouse": "^13.4.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"tailwindcss": "^4.3.2",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "bun@1.3.14"
}
