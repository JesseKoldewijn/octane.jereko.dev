{
	"name": "octane.jereko.dev",
	"version": "0.0.1",
	"private": true,
	"description": "Jereko personal website — Octane SSG",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preinstall": "node scripts/sync-octane-from-github.mjs",
		"octane:sync": "node scripts/sync-octane-from-github.mjs",
		"postinstall": "node scripts/generate-tailwind-sources.mjs",
		"predev": "node scripts/generate-tailwind-sources.mjs && node scripts/fetch-external-images.mjs",
		"build": "node scripts/generate-tailwind-sources.mjs && node scripts/fetch-external-images.mjs && bun scripts/generate-sitemap.mjs && vite build && bun scripts/prerender-static.mjs && node scripts/adapt-vercel.mjs",
		"preview": "node scripts/static-server.mjs",
		"typecheck": "tsc --noEmit && node scripts/typecheck-tsrx.mjs",
		"typecheck:tsrx": "node scripts/typecheck-tsrx.mjs",
		"lint": "oxlint src tests vite.config.ts octane.config.ts vitest.config.ts env.d.ts octane-jsx.d.ts",
		"lint:fix": "oxlint src tests vite.config.ts octane.config.ts vitest.config.ts env.d.ts octane-jsx.d.ts --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"knip": "knip",
		"check": "bun run format:check && bun run lint && bun run typecheck && bun run build && bun run test:all && bun run knip",
		"test": "vitest run --project unit --project integration --project component",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:component": "vitest run --project component",
		"test:e2e": "vitest run --project e2e",
		"test:all": "bun run test && bun run test:e2e",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@octanejs/floating-ui": "file:./vendor/octane/packages/floating-ui",
		"@octanejs/motion": "file:./vendor/octane/packages/motion",
		"@octanejs/radix": "file:./vendor/octane/packages/radix",
		"@octanejs/tanstack-router": "file:./vendor/octane/packages/tanstack-router",
		"@octanejs/vite-plugin": "file:./vendor/octane/packages/vite-plugin-octane",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"devalue": "^5.8.1",
		"motion": "^12.42.2",
		"octane": "file:./vendor/octane/packages/octane",
		"platformicons": "^9.5.0",
		"tailwind-merge": "^3.6.0",
		"workbox-window": "^7.4.1"
	},
	"devDependencies": {
		"@octanejs/testing-library": "file:./vendor/octane/packages/testing-library",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"happy-dom": "^20.10.6",
		"knip": "^6.26.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"tailwindcss": "^4.3.2",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "bun@1.3.14",
	"octaneSource": {
		"repository": "https://github.com/octanejs/octane.git",
		"ref": "main",
		"packages": {
			"octane": "packages/octane",
			"@octanejs/vite-plugin": "packages/vite-plugin-octane",
			"@octanejs/adapter-vercel": "packages/adapter-vercel",
			"@octanejs/tanstack-router": "packages/tanstack-router",
			"@octanejs/motion": "packages/motion",
			"@octanejs/radix": "packages/radix",
			"@octanejs/floating-ui": "packages/floating-ui",
			"@octanejs/testing-library": "packages/testing-library"
		}
	}
}
