{
  "name": "@octanejs/tanstack-router",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "octane": {
    "hookSlots": {
      "manual": [
        "src"
      ]
    }
  },
  "description": "TanStack Router bindings for the octane renderer — reuses @tanstack/router-core and swaps the React binding for octane's hooks.",
  "author": {
    "name": "Dominic Gannaway",
    "email": "dg@domgan.com"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octanejs/octane.git",
    "directory": "packages/tanstack-router"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./history": "./src/history.ts"
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/history": "1.162.0",
    "@tanstack/router-core": "1.171.13",
    "@tanstack/store": "^0.9.3",
    "octane": "file:../octane"
  },
  "devDependencies": {
    "@tanstack/react-router": "1.170.16",
    "@tsrx/react": "^0.2.37",
    "esbuild": "^0.28.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vitest": "^4.1.9"
  }
}
